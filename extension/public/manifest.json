{
	"manifest_version": 3,
	"name": "Aegis Wallet",
	"version": "0.1.0",
	"description": "A safety-first Sui wallet — simulates and risk-scans every transaction before you sign.",
	"action": {
		"default_popup": "popup.html",
		"default_title": "Aegis Wallet",
		"default_icon": {
			"16": "icons/icon-16.png",
			"32": "icons/icon-32.png",
			"48": "icons/icon-48.png"
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"permissions": ["storage"],
	"host_permissions": [
		"https://fullnode.testnet.sui.io/*",
		"https://faucet.testnet.sui.io/*",
		"http://127.0.0.1:8787/*",
		"http://localhost:8787/*"
	],
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["inpage.js"],
			"run_at": "document_start",
			"world": "MAIN"
		},
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["content.js"],
			"run_at": "document_start",
			"world": "ISOLATED"
		}
	]
}
