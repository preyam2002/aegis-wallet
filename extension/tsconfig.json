{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["es2022", "dom", "dom.iterable", "webworker"],
		"types": ["chrome", "node"],
		"jsx": "react-jsx",
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules"]
}
